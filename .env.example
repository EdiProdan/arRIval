# Copy this file to .env and fill in real values.
# Do not commit .env with real credentials.
# Defaults below are for Docker Compose end-to-end runtime.
# For host-run binaries, set ARRIVAL_KAFKA_BROKERS=localhost:19092.

ARRIVAL_API_BASE_URL=https://your-api-host.example.com
ARRIVAL_API_USERNAME=your_username
ARRIVAL_API_PASSWORD=your_password

ARRIVAL_KAFKA_BROKERS=redpanda:9092
ARRIVAL_KAFKA_TOPIC=bus-positions-raw
ARRIVAL_KAFKA_DELAY_TOPIC=bus-delays
ARRIVAL_PROCESSOR_GROUP=arrival-processor-bronze
ARRIVAL_AGGREGATOR_GROUP=arrival-aggregator
ARRIVAL_REALTIME_GROUP=arrival-realtime
ARRIVAL_BRONZE_DIR=data/bronze
ARRIVAL_SILVER_DIR=data/silver
ARRIVAL_GOLD_DIR=data/gold
ARRIVAL_ON_TIME_SECONDS=300
ARRIVAL_STATIC_DIR=data
ARRIVAL_INGESTER_METRICS_ADDR=:9101
ARRIVAL_PROCESSOR_METRICS_ADDR=:9102
ARRIVAL_AGGREGATOR_METRICS_ADDR=:9103
ARRIVAL_REALTIME_HTTP_ADDR=:8080
ARRIVAL_REALTIME_METRICS_ADDR=:9104
ARRIVAL_REALTIME_POSITIONS_TTL=5m
ARRIVAL_REALTIME_DELAYS_TTL=90m
ARRIVAL_REALTIME_WS_PING_INTERVAL=20s
ARRIVAL_REALTIME_WS_CLIENT_BUFFER=128
