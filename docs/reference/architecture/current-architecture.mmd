graph TB
    subgraph "Data Sources"
        API1["AUTOTROLEJ /autobusi<br/>(live positions)"]
        ODS1["OpenData ATlinije.json"]
        ODS2["OpenData ATstanice.json"]
        ODS3["OpenData ATvoznired.json"]
    end

    subgraph "Ingestion Layer"
        Ingester[Ingester Service<br/>Go - polls every 30s]
        StaticSync[StaticSync CLI<br/>Go - one-shot static downloader]
    end

    subgraph "Message Broker"
        T1["Redpanda Topic:<br/>bus-positions-raw"]
        T2["Redpanda Topic:<br/>bus-delay-observed"]
        T3["Redpanda Topic:<br/>bus-delay-predicted"]
    end

    subgraph "Processing Layer"
        Processor[Processor Service<br/>Go - Bronze + Silver + delay tracker]
        Aggregator[Aggregator Service<br/>Go - observed delay hourly stats]
        Realtime[Realtime Service<br/>Go - snapshot + websocket]
    end

    subgraph "Storage"
        Bronze["🥉 Bronze<br/>data/bronze/YYYY-MM-DD/<br/>positions.parquet"]
        SilverObs["🥈 Silver Observed<br/>data/silver/YYYY-MM-DD/<br/>observed_delays.parquet"]
        SilverPred["🥈 Silver Predicted<br/>data/silver/YYYY-MM-DD/<br/>predicted_delays.parquet"]
        Gold["🥇 Gold<br/>data/gold/YYYY-MM-DD/<br/>stats.parquet"]
        StaticFiles["Static JSON Files<br/>data/linije.json<br/>data/stanice.json<br/>data/voznired_dnevni.json"]
    end

    subgraph "Observability"
        Prom[Prometheus<br/>metrics scraping]
        Graf[Grafana<br/>provisioned dashboard]
    end

    API1 -->|HTTP poll| Ingester
    ODS1 -->|download| StaticSync
    ODS2 -->|download| StaticSync
    ODS3 -->|download| StaticSync

    StaticSync -->|write JSON| StaticFiles

    Ingester -->|publish raw JSON| T1
    T1 -->|consume| Processor

    Processor -->|write raw rows| Bronze
    Processor -->|write observed rows| SilverObs
    Processor -->|write predicted rows| SilverPred
    Processor -->|publish observed events| T2
    Processor -->|publish predicted events| T3

    T2 -->|consume observed| Aggregator
    Aggregator -->|write hourly route stats| Gold

    T2 -->|consume observed| Realtime
    T3 -->|consume predicted| Realtime

    Ingester -.->|expose metrics| Prom
    Processor -.->|expose metrics| Prom
    Aggregator -.->|expose metrics| Prom
    Realtime -.->|expose metrics| Prom
    Prom -.->|query| Graf

    classDef storage fill:#e1f5ff,stroke:#0366d6
    classDef service fill:#fff5e1,stroke:#d97706
    classDef broker fill:#f0e6ff,stroke:#8b5cf6
    classDef utility fill:#f5f5f5,stroke:#6b7280
    classDef source fill:#eefaf3,stroke:#059669
    classDef observability fill:#e6ffe6,stroke:#059669

    class Bronze,SilverObs,SilverPred,Gold,StaticFiles storage
    class Ingester,Processor,Aggregator,Realtime service
    class T1,T2,T3 broker
    class StaticSync utility
    class API1,ODS1,ODS2,ODS3 source
    class Prom,Graf observability
